<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Horario Escolar</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial, sans-serif;
}

body{
  background:#0f172a;
  color:white;
  min-height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  padding:10px;
}

.container{
  width:100%;
  max-width:820px;
}

.clock-box{
  background:#111827;
  border:2px solid #00ffaa;
  border-radius:16px;
  padding:18px;
  text-align:center;
}

.clock{
  font-size:58px;
  font-weight:bold;
  color:#00ffaa;
}

.date{
  margin-top:4px;
  font-size:14px;
  opacity:.7;
}

.current-class{
  margin-top:14px;
  background:#00ffaa;
  color:#001b14;
  border-radius:12px;
  padding:12px;
  position:relative;
}

.subject{
  font-size:28px;
  font-weight:bold;
}

.teacher{
  font-size:15px;
  margin-top:2px;
}

.time-range{
  font-size:13px;
  opacity:.75;
  margin-top:2px;
}

/* 🔥 contador esquina superior derecha */
.corner-countdown{
  position:absolute;
  top:8px;
  right:10px;
  font-size:14px;
  font-weight:bold;
  background:rgba(0,0,0,0.15);
  padding:4px 8px;
  border-radius:8px;
}

.schedule{
  margin-top:14px;
  overflow-x:auto;
}

table{
  width:100%;
  border-collapse:collapse;
  background:#111827;
  border-radius:14px;
  overflow:hidden;
}

th{
  background:#1e293b;
  color:#00ffaa;
  padding:8px;
  font-size:13px;
}

td{
  border:1px solid rgba(255,255,255,.05);
  padding:7px;
  text-align:center;
}

.period{
  background:#0f172a;
  font-size:12px;
  font-weight:bold;
}

.lesson{
  font-size:13px;
  font-weight:bold;
}

.prof{
  font-size:11px;
  opacity:.7;
  margin-top:2px;
}

.break{
  background:#f59e0b;
  color:black;
  font-weight:bold;
}

.active{
  background:#00ffaa !important;
  color:#001b14;
}
</style>
</head>

<body>

<div class="container">

  <div class="clock-box">
    <div class="clock" id="clock">00:00:00</div>
    <div class="date" id="date"></div>

    <div class="current-class">

      <!-- ⏳ contador arriba a la derecha -->
      <div class="corner-countdown" id="countdown">⏳ 00:00</div>

      <div class="subject" id="subject">Cargando...</div>
      <div class="teacher" id="teacher"></div>
      <div class="time-range" id="timeRange"></div>

    </div>
  </div>

  <div class="schedule">
    <table>
      <tr>
        <th>Hora</th><th>L</th><th>M</th><th>X</th><th>J</th><th>V</th>
      </tr>

      <tr>
        <td class="period">8:30-9:25</td>
        <td id="1-1"><div class="lesson">GYH</div><div class="prof">María</div></td>
        <td id="2-1"><div class="lesson">MAT</div><div class="prof">Roxana</div></td>
        <td id="3-1"><div class="lesson">MUS</div><div class="prof">Pedro</div></td>
        <td id="4-1"><div class="lesson">EF</div><div class="prof">José Luis</div></td>
        <td id="5-1"><div class="lesson">GYH</div><div class="prof">María</div></td>
      </tr>

      <tr>
        <td class="period">9:25-10:20</td>
        <td id="1-2"><div class="lesson">MAT</div><div class="prof">Roxana</div></td>
        <td id="2-2"><div class="lesson">PLA</div><div class="prof">Ana G.</div></td>
        <td id="3-2"><div class="lesson">ING</div><div class="prof">Ana C.</div></td>
        <td id="4-2"><div class="lesson">PLA</div><div class="prof">Ana G.</div></td>
        <td id="5-2"><div class="lesson">MUS</div><div class="prof">Pedro</div></td>
      </tr>

      <tr>
        <td class="period">10:20-11:15</td>
        <td id="1-3"><div class="lesson">ING</div><div class="prof">Ana C.</div></td>
        <td id="2-3"><div class="lesson">ING</div><div class="prof">Ana C.</div></td>
        <td id="3-3"><div class="lesson">FRA</div><div class="prof">Eva</div></td>
        <td id="4-3"><div class="lesson">FYQ</div><div class="prof">Alberto</div></td>
        <td id="5-3"><div class="lesson">ING</div><div class="prof">Ana C.</div></td>
      </tr>

      <tr>
        <td class="break">11:15-11:45</td>
        <td colspan="5" class="break">☀️ RECREO ☀️</td>
      </tr>

      <tr>
        <td class="period">11:45-12:40</td>
        <td id="1-4"><div class="lesson">FRA</div><div class="prof">Eva</div></td>
        <td id="2-4"><div class="lesson">FYQ</div><div class="prof">Alberto</div></td>
        <td id="3-4"><div class="lesson">LYL</div><div class="prof">María</div></td>
        <td id="4-4"><div class="lesson">MAT</div><div class="prof">Roxana</div></td>
        <td id="5-4"><div class="lesson">LYL</div><div class="prof">María</div></td>
      </tr>

      <tr>
        <td class="period">12:40-13:35</td>
        <td id="1-5"><div class="lesson">LYL</div><div class="prof">María</div></td>
        <td id="2-5"><div class="lesson">EV</div><div class="prof">Germán</div></td>
        <td id="3-5"><div class="lesson">REL</div><div class="prof">Germán</div></td>
        <td id="4-5"><div class="lesson">GYH</div><div class="prof">María</div></td>
        <td id="5-5"><div class="lesson">EV</div><div class="prof">Germán</div></td>
      </tr>

      <tr>
        <td class="period">13:35-14:30</td>
        <td id="1-6"><div class="lesson">EF</div><div class="prof">José Luis</div></td>
        <td id="2-6"><div class="lesson">TUT</div><div class="prof">Alberto</div></td>
        <td id="3-6"><div class="lesson">MAT</div><div class="prof">Roxana</div></td>
        <td id="4-6"><div class="lesson">LYL</div><div class="prof">María</div></td>
        <td id="5-6"><div class="lesson">FYQ</div><div class="prof">Alberto</div></td>
      </tr>
    </table>
  </div>
</div>

<script>
const schedule = [
  ["08:30","09:25",1],
  ["09:25","10:20",2],
  ["10:20","11:15",3],
  ["11:15","11:45","RECREO"],
  ["11:45","12:40",4],
  ["12:40","13:35",5],
  ["13:35","14:30",6]
];

const subjects = {
  "1-1":["GYH","María"],"1-2":["MAT","Roxana"],"1-3":["ING","Ana C."],"1-4":["FRA","Eva"],"1-5":["LYL","María"],"1-6":["EF","José Luis"],
  "2-1":["MAT","Roxana"],"2-2":["PLA","Ana G."],"2-3":["ING","Ana C."],"2-4":["FYQ","Alberto"],"2-5":["EV","Germán"],"2-6":["TUT","Alberto"],
  "3-1":["MUS","Pedro"],"3-2":["ING","Ana C."],"3-3":["FRA","Eva"],"3-4":["LYL","María"],"3-5":["REL","Germán"],"3-6":["MAT","Roxana"],
  "4-1":["EF","José Luis"],"4-2":["PLA","Ana G."],"4-3":["FYQ","Alberto"],"4-4":["MAT","Roxana"],"4-5":["GYH","María"],"4-6":["LYL","María"],
  "5-1":["GYH","María"],"5-2":["MUS","Pedro"],"5-3":["ING","Ana C."],"5-4":["LYL","María"],"5-5":["EV","Germán"],"5-6":["FYQ","Alberto"]
};

function getMadridTime() {
  const now = new Date();

  const fmtTime = new Intl.DateTimeFormat('es-ES', {
    timeZone: 'Europe/Madrid',
    hour:'2-digit', minute:'2-digit', second:'2-digit'
  });

  const fmtDate = new Intl.DateTimeFormat('es-ES', {
    timeZone: 'Europe/Madrid',
    weekday:'long', day:'numeric', month:'long'
  });

  const fmtDay = new Intl.DateTimeFormat('en-US', {
    timeZone:'Europe/Madrid',
    weekday:'short'
  });

  return {
    t: fmtTime.format(now),
    d: fmtDate.format(now),
    day: fmtDay.format(now)
  };
}

function dayToNum(day){
  return {Mon:1,Tue:2,Wed:3,Thu:4,Fri:5,Sat:6,Sun:0}[day];
}

function update(){

  const {t,d,day} = getMadridTime();
  const dayNum = dayToNum(day);
  const currentHM = t.slice(0,5);

  const now = new Date();
  const madridNow = new Date(
    now.toLocaleString("en-US",{timeZone:"Europe/Madrid"})
  );

  document.getElementById("clock").textContent = t;
  document.getElementById("date").textContent = d;

  document.querySelectorAll("td").forEach(e=>e.classList.remove("active"));

  if(dayNum===0 || dayNum===6){
    document.getElementById("subject").textContent="🏡 CASA";
    document.getElementById("teacher").textContent="Fin de semana";
    document.getElementById("timeRange").textContent="Libre total";
    document.getElementById("countdown").textContent="⏳ 00:00";
    return;
  }

  if(currentHM>="14:30" || currentHM<"08:30"){
    document.getElementById("subject").textContent="🏡 CASA";
    document.getElementById("teacher").textContent="Tiempo libre";
    document.getElementById("timeRange").textContent="14:30 - 08:30";
    document.getElementById("countdown").textContent="⏳ 00:00";
    return;
  }

  for(const b of schedule){

    if(currentHM>=b[0] && currentHM<b[1]){

      const [endH,endM] = b[1].split(":").map(Number);

      const endTime = new Date(madridNow);
      endTime.setHours(endH,endM,0,0);

      const diff = endTime - madridNow;

      const mins = Math.floor(diff/60000);
      const secs = Math.floor((diff%60000)/1000);

      document.getElementById("countdown").textContent =
        "⏳ " +
        String(mins).padStart(2,"0") + ":" +
        String(secs).padStart(2,"0");

      if(b[2]==="RECREO"){
        document.getElementById("subject").textContent="☀️ RECREO";
        document.getElementById("teacher").textContent="";
        document.getElementById("timeRange").textContent=`${b[0]} - ${b[1]}`;
        return;
      }

      const key = dayNum+"-"+b[2];
      const info = subjects[key];

      document.getElementById("subject").textContent = info[0];
      document.getElementById("teacher").textContent = "👨‍🏫 " + info[1];
      document.getElementById("timeRange").textContent = `${b[0]} - ${b[1]}`;

      const cell = document.getElementById(key);
      if(cell) cell.classList.add("active");

      return;
    }
  }

  document.getElementById("subject").textContent="🏡 CASA";
  document.getElementById("teacher").textContent="Tiempo libre";
  document.getElementById("timeRange").textContent="14:30 - 08:30";
  document.getElementById("countdown").textContent="⏳ 00:00";
}

setInterval(update,1000);
update();
</script>

</body>
</html>
